{
  "mcpServers": {
    "notionApi": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_TOKEN": "${NOTION_API_KEY}"
      }
    },
    "shrimp-task-manager": {
      "command": "node",
      "args": ["H:/my-workspace/workspace/mcp-shrimp-task-manager/dist/index.js"],
      "env": {
        "DATA_DIR": "H:/my-workspace/workspace/notion-cms-project/shrimp_date",
        "TEMPLATES_USE": "en",
        "ENABLE_GUI": "false"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
