# ─────────────────────────────────────────────────────────────
# 환경변수 템플릿
# 이 파일을 복사해 ".env.local" 로 만든 뒤 실제 값을 채워 넣으세요.
#   복사 명령: cp .env.example .env.local   (Windows PowerShell: Copy-Item .env.example .env.local)
# .env.local 은 .gitignore 에 의해 커밋되지 않습니다.
# ─────────────────────────────────────────────────────────────

# ── 관리자 인증 ──────────────────────────────────────────────
# 관리자 로그인 계정의 아이디 / 비밀번호
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 세션(JWT) 서명에 사용하는 비밀키 (32자 이상 권장)
# 무작위 값 생성 예시:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# ── Supabase ─────────────────────────────────────────────────
# Supabase 프로젝트 URL (예: https://xxxxxxxxxxxx.supabase.co)
# Supabase 대시보드 > Project Settings > API 에서 확인할 수 있습니다.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon(public) 키 — 브라우저에 노출되어도 되는 공개 키
# Supabase 대시보드 > Project Settings > API > Project API keys 에서 확인할 수 있습니다.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Notion (CMS) ─────────────────────────────────────────────
# Notion 통합(Integration) 시크릿 키 — 게시글 데이터를 읽어오는 데 사용합니다.
# 발급: https://www.notion.so/my-integrations 에서 통합 생성 후 "Internal Integration Secret" 복사
# ⚠️ 비밀값입니다. 서버에서만 사용하며 절대 브라우저(NEXT_PUBLIC_ 접두사)로 노출하지 마세요.
NOTION_API_KEY=

# 게시글이 저장된 Notion 데이터베이스 ID
# 데이터베이스를 열었을 때 URL 의 "notion.so/<워크스페이스>/<여기 32자리>?v=..." 부분입니다.
# 형식: 하이픈(-) 없는 32자리 16진수 (예: 1a2b3c4d5e6f7890abcdef1234567890)
# (해당 통합을 데이터베이스에 Connection 으로 연결해야 API 접근이 허용됩니다.)
NOTION_DATABASE_ID=
