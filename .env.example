# ─────────────────────────────────────────────────────────────
# 환경변수 템플릿
# 이 파일을 복사해 ".env.local" 로 만든 뒤 실제 값을 채워 넣으세요.
#   복사 명령: cp .env.example .env.local   (Windows PowerShell: Copy-Item .env.example .env.local)
# .env.local 은 .gitignore 에 의해 커밋되지 않습니다.
# ─────────────────────────────────────────────────────────────

# ── 관리자 인증 ──────────────────────────────────────────────
# 관리자 로그인 계정의 아이디 / 비밀번호
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 세션(JWT) 서명에 사용하는 비밀키 (32자 이상 권장)
# 무작위 값 생성 예시:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# ── Supabase ─────────────────────────────────────────────────
# Supabase 프로젝트 URL (예: https://xxxxxxxxxxxx.supabase.co)
# Supabase 대시보드 > Project Settings > API 에서 확인할 수 있습니다.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon(public) 키 — 브라우저에 노출되어도 되는 공개 키
# Supabase 대시보드 > Project Settings > API > Project API keys 에서 확인할 수 있습니다.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
