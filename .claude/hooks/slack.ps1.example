# ============================================================================
# slack.ps1.example — Slack 알림 설정 템플릿
# ----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 같은 폴더에 "slack.ps1" 이라는 이름으로 복사한다.
#        (PowerShell)  Copy-Item .claude/hooks/slack.ps1.example .claude/hooks/slack.ps1
#   2) 복사한 slack.ps1 의 $SlackWebhookUrl 에 발급받은 Webhook URL을 넣는다.
#   3) slack.ps1 은 .gitignore 로 추적 제외되므로 비밀 URL이 깃에 올라가지 않는다.
#        (이 .example 템플릿만 공유되고, 실제 값이 든 slack.ps1 은 개인 로컬에만 존재)
#   ※ slack.ps1 이 없으면 notify-*.ps1 은 Slack 전송을 건너뛰고 PC 소리 알림만 동작한다.
#
# Slack Incoming Webhook URL 발급:
#   api.slack.com/apps → Create New App(From scratch) → Incoming Webhooks On
#   → Add New Webhook to Workspace → 채널 선택 → URL 복사
# ============================================================================

# 발급받은 실제 URL("https://hooks.slack.com/services/T.../B.../...")로 교체하세요.
$script:SlackWebhookUrl = "https://hooks.slack.com/services/XXX/YYY/ZZZ"

function Send-SlackMessage {
    param(
        [string]$Text  # Slack 채널에 표시할 메시지 본문
    )

    # URL이 비어 있거나 템플릿("XXX") 그대로면 전송하지 않는다 → 소리 알림만 동작
    if (-not $script:SlackWebhookUrl -or $script:SlackWebhookUrl -like "*XXX*") { return }

    try {
        # Slack은 { "text": "..." } 형태의 JSON 본문을 기대한다
        $payload = @{ text = $Text } | ConvertTo-Json -Compress  # 전송할 JSON 본문

        # ⚠️ 인코딩 핵심:
        # Windows PowerShell 5.1의 Invoke-RestMethod 는 문자열 본문을 보낼 때
        # charset 이 없으면 비-UTF8(Latin1/ASCII)로 인코딩해 한글·이모지가 '?'로 깨진다.
        # → JSON 문자열을 UTF-8 바이트로 직접 변환해 전송하면 깨지지 않는다.
        $bodyBytes = [System.Text.Encoding]::UTF8.GetBytes($payload)  # UTF-8 바이트 본문

        Invoke-RestMethod -Uri $script:SlackWebhookUrl -Method Post `
            -ContentType 'application/json; charset=utf-8' -Body $bodyBytes -TimeoutSec 5 | Out-Null
    } catch {
        # 네트워크 오류 등 알림 실패가 Claude Code 작업 흐름을 막지 않도록 예외는 무시한다
    }
}
